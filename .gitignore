*.key
*.evk
*.ctxt
*.bin
/keys/
/artifacts/

# Benchmark output blobs (commit the report, not raw dumps)
/benchmarks/output/
/benchmarks/*.npz

# Docs site build
/site/

# Editors / OS
.idea/
.vscode/
.DS_Store
*.swp
